BOT_TOKEN=
PRIVATE_GROUP_ID=
ADMIN_TG_IDS=

# Railway Postgres URL is accepted as-is.
# App will normalize postgresql:// -> postgresql+asyncpg:// automatically.
DATABASE_URL=postgresql://postgres:password@postgres.railway.internal:5432/railway
REDIS_URL=redis://default:password@redis.railway.internal:6379

APP_TZ=Europe/Moscow
MEETING_PROVIDER=manual
DEFAULT_DURATION_MIN=60
TELEMOST_URL=https://telemost.yandex.ru/
GOOGLE_SHEET_ID=
GOOGLE_SHEETS_CREDENTIALS_JSON=
SHEETS_OUTBOX_PATH=backups/sheets_outbox.jsonl

